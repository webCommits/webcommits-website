</head>

<body>
  {% include "header.njk" %}

  <main>
    {% block content %} {% endblock %}
  </main>

  {% include "footer.njk" %}

  <div id="consent-banner" class="consent-banner" role="dialog" aria-label="Cookie Consent" aria-describedby="consent-text" style="display:none;">
    <p id="consent-text" data-i18n="consent.text">
      Diese Website nutzt selbst gehostete, cookielose Analyse mit Umami. Sie wird nur mit Ihrer Zustimmung aktiviert.
    </p>
    <div class="consent-banner__actions">
      <button id="consent-accept" class="btn btn--primary" data-i18n="consent.accept">Akzeptieren</button>
      <button id="consent-decline" class="btn btn--ghost" data-i18n="consent.decline">Ablehnen</button>
    </div>
  </div>
</body>

</html>
